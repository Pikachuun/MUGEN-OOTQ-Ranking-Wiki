<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>编辑 - <%= title %></title>
  <link rel="stylesheet" href="styles.css">
  <script src="i18n.js" defer></script>
</head>
<body>
  <header>
    <div class="container header-inner">
      <a href="" class="logo">
        <span>📃</span>
        <span>MUGEN OOTQ Wiki</span>
      </a>
      <div class="header-controls">
        <button id="themeToggle" class="btn" aria-label="Toggle theme">🌙</button>
        <select id="langSelect" class="lang-select">
          <option value="zh">中文</option>
          <option value="en">English</option>
          <option value="ja">日本語</option>
        </select>
      </div>
    </div>
  </header>

  <nav class="container">
    <div style="padding: 10px 0; border-bottom: 1px solid var(--border-color);">
      <a href="" data-i18n="home">首页</a>
      <a href="characters/" data-i18n="characters" style="margin-left: 20px;">角色</a>
      <a href="glossary/" data-i18n="glossary" style="margin-left: 20px;">术语</a>
    </div>
  </nav>

  <main class="container">
    <div class="page-header">
      <h1>角色 Issue 创建工具</h1>
      <p class="lead">填写信息后生成 Issue 草稿，提交后自动显示在角色列表和详情页。</p>
    </div>

    <div class="format-hint">
      <h3>说明</h3>
      <ul>
        <li><strong>Issue 标题</strong> 作为角色显示名称</li>
        <li><strong>Labels</strong> 用于设置分级、URL 标识和标签，可用前缀：<code>tier:</code>、<code>level:</code>、<code>slug:</code></li>
        <li>其他 label 自动作为角色标签</li>
        <li><strong>正文</strong> 使用 GitHub Flavored Markdown 编写，图片拖拽上传后会自动识别</li>
        <li>已有 Issue 中的 <code>```json</code> 元数据块仍然兼容（系统会自动忽略）</li>
      </ul>
    </div>

    <div class="edit-form">
      <div class="form-group">
        <label>角色名称 (Issue 标题)</label>
        <input type="text" id="title" placeholder="例如: My Character">
      </div>

      <div class="form-group">
        <label>Slug (URL 标识，留空自动生成)</label>
        <input type="text" id="slug" placeholder="例如: my-character">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Tier (分级)</label>
          <select id="ootqTier">
            <option value="low">low (论外下位)</option>
            <option value="mid">mid (论外中位)</option>
            <option value="high">high (论外上位)</option>
            <option value="top">top (论外最上位)</option>
          </select>
        </div>

        <div class="form-group">
          <label>Level (级别名，可选，如 S、A+)</label>
          <input type="text" id="ootqLevel" placeholder="例如: S">
        </div>
      </div>

      <div class="form-group">
        <label>标签 (逗号分隔，除 tier/level/slug 外的 label 自动作为标签)</label>
        <input type="text" id="tags" placeholder="例如: 参考, 防御型, 改造">
      </div>

      <div class="form-group">
        <label>正文 (Markdown)</label>
        <textarea id="body" rows="12" placeholder="使用 Markdown 编写角色介绍，图片可拖拽上传后在正文中引用&#10;&#10;## 基本信息&#10;&#10;- **作者**：&#10;- **来源**：&#10;- **启动方式**：&#10;- **下载链接**：&#10;&#10;## 角色介绍&#10;&#10;在此处编写详细描述..."></textarea>
      </div>

      <div class="form-actions">
        <button id="generateBtn" class="btn btn-primary" type="button">生成 Issue 草稿</button>
      </div>

      <div id="preview" class="json-preview" style="display:none;">
        <h3>预览</h3>
        <div class="preview-labels" id="labelPreview"></div>
        <pre><code id="bodyPreview"></code></pre>
        <div class="form-actions">
          <a id="issueBtn" href="#" target="_blank" rel="noopener" class="btn btn-primary">打开 GitHub 新建 Issue</a>
        </div>
      </div>
    </div>
  </main>

  <footer>
    <div class="container">
      <p>&copy; 2026 MUGEN OOTQ Ranking Wiki</p>
    </div>
  </footer>

  <script>
(function () {
  const issueBase = 'https://github.com/mugen-community/MUGEN-OOTQ-Ranking-Wiki/issues/new?template=character_submission.md';

  document.getElementById('generateBtn').addEventListener('click', function () {
    const title = document.getElementById('title').value.trim();
    if (!title) { alert('请填写角色名称'); return; }

    const slug = document.getElementById('slug').value.trim();
    const tier = document.getElementById('ootqTier').value;
    const level = document.getElementById('ootqLevel').value.trim();
    const rawTags = document.getElementById('tags').value.trim();
    const body = document.getElementById('body').value.trim() || '暂无内容';

    const labels = ['character'];
    if (slug) labels.push('slug:' + slug);
    labels.push('tier:' + tier);
    if (level) labels.push('level:' + level);
    if (rawTags) {
      rawTags.split(',').map(t => t.trim()).filter(Boolean).forEach(t => labels.push(t));
    }

    document.getElementById('labelPreview').textContent = 'Labels: ' + labels.join(', ');
    document.getElementById('bodyPreview').textContent = body;
    document.getElementById('preview').style.display = 'block';

    const url = new URL(issueBase);
    url.searchParams.set('title', '[character] ' + title);
    url.searchParams.set('body', body);
    url.searchParams.set('labels', labels.join(','));
    document.getElementById('issueBtn').href = url.toString();
  });

  document.getElementById('title').addEventListener('input', function () {
    const slugInput = document.getElementById('slug');
    if (!slugInput.value.trim()) {
      slugInput.value = this.value
        .trim()
        .toLowerCase()
        .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }
  });
})();
  </script>

  <style>
.edit-form {
  max-width: 780px;
  margin: 0 auto;
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 24px;
}

.form-group {
  margin-bottom: 20px;
}

.form-row {
  display: flex;
  gap: 16px;
}

.form-row .form-group {
  flex: 1;
}

.form-group label {
  display: block;
  font-weight: 500;
  margin-bottom: 6px;
  color: var(--text-primary);
}

.form-group input,
.form-group textarea,
.form-group select {
  width: 100%;
  padding: 10px 12px;
  border: 1px solid var(--border-color);
  border-radius: 6px;
  background: var(--bg-secondary);
  color: var(--text-primary);
  font-size: 1em;
  font-family: inherit;
  box-sizing: border-box;
}

.form-group input:focus,
.form-group textarea:focus,
.form-group select:focus {
  outline: none;
  border-color: var(--link-color);
}

.form-group textarea {
  resize: vertical;
  min-height: 100px;
}

.form-actions {
  display: flex;
  gap: 12px;
  margin-top: 20px;
  flex-wrap: wrap;
}

.btn-primary {
  background: var(--link-color);
  color: #fff;
  border: none;
  padding: 10px 20px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 1em;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
}

.btn-primary:hover {
  opacity: 0.92;
  text-decoration: none;
}

.json-preview {
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--border-color);
}

.json-preview h3 {
  margin-bottom: 12px;
  font-size: 1.1em;
}

.json-preview pre {
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 6px;
  padding: 16px;
  overflow-x: auto;
  max-height: 420px;
  white-space: pre-wrap;
}

.json-preview code {
  font-family: Consolas, Monaco, monospace;
  font-size: 0.9em;
  white-space: pre;
}

.preview-labels {
  margin-bottom: 12px;
  padding: 8px 12px;
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 6px;
  font-size: 0.92em;
  color: var(--text-secondary);
  word-break: break-all;
}

.format-hint {
  max-width: 780px;
  margin: 0 auto 20px;
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 16px 20px;
  font-size: 0.92em;
}

.format-hint h3 {
  margin: 0 0 8px;
  font-size: 1em;
}

.format-hint ul {
  margin: 0;
  padding-left: 20px;
}

.format-hint li {
  margin-bottom: 6px;
  line-height: 1.5;
}

.format-hint code {
  background: var(--bg-card);
  border: 1px solid var(--border-color);
  border-radius: 3px;
  padding: 1px 5px;
  font-size: 0.88em;
  font-family: Consolas, Monaco, monospace;
}
  </style>
</body>
</html>
