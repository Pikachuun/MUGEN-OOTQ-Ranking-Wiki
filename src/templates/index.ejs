<div class="page-header">
  <h1>MUGEN OOTQ Ranking Wiki</h1>
  <div class="search-box">
    <input type="search" id="searchInput" data-i18n-placeholder="search" placeholder="搜索...">
  </div>
</div>

<section class="section">
  <div class="section-header">
    <h2 data-i18n="characters">角色</h2>
    <a href="<%= r('characters/') %>" style="font-size:0.9em;">查看全部 →</a>
  </div>
  <div class="card-grid" id="charactersGrid">
    <% characters.forEach((char, idx) => { %>
      <a class="card char-card" href="<%= r('characters/') %><%= char.slug %>/">
        <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:8px;">
          <h3 data-i18n="<%= 'c:' + idx + ':title' %>"><%= getField(char.meta.title, 'zh') %></h3>
          <% if (char.meta.ootqLevel) { %>
            <span class="ootq-badge ootq-<%= char.meta.ootqTier || 'low' %>" data-i18n="<%= 'c:' + idx + ':ootqLevel' %>"><%= getField(char.meta.ootqLevel, 'zh') %></span>
          <% } %>
        </div>
        <p data-i18n="<%= 'c:' + idx + ':summary' %>"><%= getField(char.meta.summary, 'zh') %></p>
        <% const tagsArr = Array.isArray(char.meta.tags) ? char.meta.tags : (char.meta.tags.zh || []); %>
        <% if (tagsArr.length) { %>
          <div class="tags" data-i18n="<%= 'c:' + idx + ':tags' %>" data-tags='<%= JSON.stringify(char.meta.tags) %>'>
            <% tagsArr.slice(0, 3).forEach(tag => { %>
              <span class="tag"><%= getField(tag, 'zh') %></span>
            <% }); %>
          </div>
        <% } %>
      </a>
    <% }); %>
    <% if (characters.length === 0) { %>
      <div class="empty-state">
        <p data-i18n="noContent">暂无角色</p>
      </div>
    <% } %>
  </div>
</section>

<section class="section">
  <div class="section-header">
    <h2 data-i18n="glossary">术语</h2>
    <a href="<%= r('glossary/') %>" style="font-size:0.9em;">查看全部 →</a>
  </div>
  <div class="card-grid" id="glossaryGrid">
    <% terms.forEach((term, idx) => { %>
      <a class="card glossary-card" href="<%= r('glossary/') %><%= term.slug %>/">
        <h3 data-i18n="<%= 't:' + idx + ':title' %>"><%= getField(term.meta.title, 'zh') %></h3>
        <% if (term.meta.summary) { %>
          <p data-i18n="<%= 't:' + idx + ':summary' %>"><%= getField(term.meta.summary, 'zh') %></p>
        <% } %>
      </a>
    <% }); %>
    <% if (terms.length === 0) { %>
      <div class="empty-state">
        <p data-i18n="noContent">暂无术语</p>
      </div>
    <% } %>
  </div>
</section>

<script>
window.__chars = <%- JSON.stringify(characters.map(c => c.meta)) %>;
window.__terms = <%- JSON.stringify(terms.map(t => t.meta)) %>;
</script>
